# SERVER
PORT=4000
NODE_ENV=production

# CORS (Frontend URL in production)
# Example: https://my-invoice-manager.vercel.app
CORS_ORIGIN=http://localhost:5173

# DATABASE
# Neon Postgres Connection String
# Example: postgres://[user]:[password]@[endpoint].neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://user:pass@localhost:5432/invoice_tracker

# AUTHENTICATION
# Generate a strong 64-char hex string in production
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d

# ALGORAND BLOCKCHAIN
ALGORAND_ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_PORT=443
ALGORAND_ALGOD_TOKEN=
ALGORAND_EXPLORER_BASE_URL=https://testnet.algoexplorer.io/tx/

# ANCHOR SETUP (Optional: Will simulate anchors if omitted)
# 25-word mnemonic phrase for the wallet paying the transaction fee
ALGORAND_ANCHOR_MNEMONIC=
# The target wallet address holding the note data (often the same as the sender)
ALGORAND_ANCHOR_RECEIVER=

# BUSINESS INFO (Used across PDFs and metrics)
BUSINESS_NAME="Your Business Name"
BUSINESS_ADDRESS="123 Street Address"
BUSINESS_CITY_STATE="Mumbai, MH 400001"
BUSINESS_PHONE="(000) 000-0000"
BUSINESS_EMAIL="contact@yourbusiness.com"

# EMAIL CONFIGURATION (Nodemailer Gmail SMTP)
# User configures these values to enable invoice and reminder emails
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
